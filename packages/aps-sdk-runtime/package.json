{
  "name": "@aeoess/aps-sdk-runtime",
  "version": "0.1.0",
  "description": "APS Runtime Passport SDK for local verifier integration (Prototype 1, Stream B)",
  "license": "Apache-2.0",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "npx tsx --test __tests__/roundtrip.test.ts __tests__/check.test.ts __tests__/sinks.test.ts __tests__/recovery.test.ts"
  },
  "napi": {
    "name": "aps-sdk-runtime",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
