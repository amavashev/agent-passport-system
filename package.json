{
  "name": "agent-passport-system",
  "version": "1.3.0",
  "description": "The Agent Social Contract — cryptographic identity, ethical governance, beneficiary attribution, and protocol-native communication for autonomous AI agents.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "bin": {
    "agent-passport": "dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/src/cli/index.js",
    "test": "tsx --test tests/passport.test.ts tests/v1.1-integration.ts tests/adversarial.ts tests/v2.0-integration.ts tests/contract.test.ts tests/agora.test.ts",
    "test:quick": "tsx --test tests/passport.test.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "agent",
    "passport",
    "identity",
    "trust",
    "ai",
    "autonomous",
    "agora",
    "communication",
    "ed25519",
    "delegation",
    "accountability",
    "multi-agent",
    "governance",
    "values",
    "attribution",
    "merkle",
    "social-contract"
  ],
  "author": "Tymofii Pidlisnyi <tima@aeoess.com> (https://aeoess.com)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aeoess/agent-passport-system.git"
  },
  "homepage": "https://aeoess.com/passport.html",
  "bugs": {
    "url": "https://github.com/aeoess/agent-passport-system/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/src/**/*",
    "values/",
    "README.md",
    "LICENSE"
  ]
}
